# GitHub personal access token (optional but recommended).
# Without it, the GitHub API allows 60 requests/hour; with it, 5000/hour.
# Create one at https://github.com/settings/tokens — no scopes needed (public repos only).
GITHUB_TOKEN=

# SMTP credentials for the contact form (optional).
# When unset, submissions are logged to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where contact form submissions are delivered.
CONTACT_EMAIL=allanbinu197@gmail.com
